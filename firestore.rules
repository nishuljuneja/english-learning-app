rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Check if user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper: Check if user is accessing their own data
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // User profiles
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false; // Users cannot delete their profiles

      // Vocabulary progress (subcollection)
      match /vocabularyProgress/{wordId} {
        allow read, write: if isOwner(userId);
      }

      // Lesson progress (subcollection)
      match /lessonProgress/{lessonId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Placement test results
    match /placementResults/{resultId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // Vocabulary words (shared content — read-only for users)
    match /vocabulary/{wordId} {
      allow read: if true; // Public read for content
      allow write: if false; // Only admin writes via console/scripts
    }

    // Grammar lessons (shared content — read-only for users)
    match /grammarLessons/{lessonId} {
      allow read: if true;
      allow write: if false;
    }

    // Reading passages (shared content — read-only for users)
    match /readingPassages/{passageId} {
      allow read: if true;
      allow write: if false;
    }

    // Leaderboard (derived from user profiles)
    match /leaderboard/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
